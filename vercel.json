{
    "builds": [
        {
            "src": "portfolio_django/wsgi.py",
            "use": "@vercel/python",
            "config":{
                "maxLambdaSize": "15mb",
                "runtime" : "pyhton3.12"
            }
        }
    ],

    "routes" : [
        {
            "src":"/(.*)",
            "dest": "portfolio_django/wsgi.py"
        },
        {
            "src":"/static/(./*)",
            "dest": "/static/$1"
        }
    ]
}